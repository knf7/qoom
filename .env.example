# =========================================================================
# QOOM ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================

# General Environment settings
NODE_ENV=development
PORT=3001

# Supabase PostgreSQL connection
# Example: postgresql://postgres:your-db-password@db.supabase.co:5432/postgres?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qoom?schema=public

# Redis connection (Used for BullMQ job processor and rate limiter backends)
REDIS_URL=redis://localhost:6379

# DeepSeek API key (Mandatory for Multi-Agent calculations)
DEEPSEEK_API_KEY=your_deepseek_api_key_goes_here

# JWT authentication key (Keep long and complex in production)
JWT_SECRET=super_secret_qoom_jwt_signing_key_at_least_12_chars

# Frontend Client URL (Used for rigid CORS filtering)
FRONTEND_URL=http://localhost:5173

# Support & Requests Destination Email
ADMIN_SUPPORT_EMAIL=your_support_destination_email_goes_here
